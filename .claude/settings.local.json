{
  "permissions": {
    "allow": [
      "Bash(supabase functions:*)",
      "Bash(git:*)"
    ]
  },
  "hooks": {
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash.audit-financeiro.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash.context-injector.sh"
          }
        ]
      }
    ]
  }
}
