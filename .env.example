# Sentry (opcional — monitoramento de erros em produção)
# Obtenha o DSN em: sentry.io → Projeto → Settings → Client Keys (DSN)
# VITE_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project-id>

# Supabase (obrigatório para o frontend)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-anon-key>
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# Cloudflare Pages / Workers (setar como secret no dashboard da Cloudflare)
# wrangler secret put VITE_CFN_API_KEY
VITE_CFN_API_KEY=<your-cfn-api-key>

# Playwright E2E (opcional - só para testes autenticados)
# PW_BASE_URL=https://app.vectracargo.com.br
# PW_TEST_USER=seu-email@dominio.com.br
# PW_TEST_PASSWORD=<sua-senha-de-teste>

# E2E seed (obrigatório só para specs *.seeded.spec.ts - backend real)
# SUPABASE_URL=https://<your-project-ref>.supabase.co
# SUPABASE_SR_KEY=<your-supabase-sr-key>

# Auditoria de trips (npm run audit:trips) — chave admin para bypass RLS
# Use o mesmo valor de SUPABASE_SR_KEY se já tiver; senão obtenha em Supabase → Settings → API
# SUPABASE_SR_KEY=<your-supabase-sr-key>

# Notification hub (Edge Function notification-hub)
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=<your-evolution-api-key>
# EVOLUTION_INSTANCE=<your-instance-name>

# Google Maps API (para validação de CEP e visualização de rotas)
# Obtenha em: https://console.cloud.google.com → Credentials → Create API Key
# Habilite: Geocoding API + Maps JavaScript API
# Restringir por: HTTP referrers (websites) - adicione localhost:5173 para dev
VITE_GOOGLE_MAPS_API_KEY=<your-google-maps-api-key>
