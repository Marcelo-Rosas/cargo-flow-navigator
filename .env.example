# Supabase (obrigatório para o frontend)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-anon-key>
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# Cloudflare Pages / Workers (setar como secret no dashboard da Cloudflare)
# wrangler secret put VITE_CFN_API_KEY
VITE_CFN_API_KEY=<your-cfn-api-key>

# Playwright E2E (opcional - só para testes autenticados)
# PW_BASE_URL=https://app.vectracargo.com.br
# PW_TEST_USER=seu-email@dominio.com.br
# PW_TEST_PASSWORD=<sua-senha-de-teste>

# E2E seed (obrigatório só para specs *.seeded.spec.ts - backend real)
# SUPABASE_URL=https://<your-project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Notification hub (Edge Function notification-hub)
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=<your-evolution-api-key>
# EVOLUTION_INSTANCE=<your-instance-name>
