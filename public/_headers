# index.html nunca deve ser cacheado — sempre busca a versão mais recente
# para evitar "Failed to fetch dynamically imported module" após deploys
/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Assets com hash no nome podem ser cacheados por 1 ano (imutáveis)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
