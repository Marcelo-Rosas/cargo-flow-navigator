{
  "name": "cfn-debugger-mcp",
  "version": "1.0.0",
  "description": "MCP Server for Cargo Flow Navigator debugging - RLS, Currency, Edge Functions monitoring",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "debug:component": "npm run build && node scripts/run-debug-component.mjs",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["mcp", "debugging", "cargo-flow-navigator", "rls", "currency"],
  "author": "Marcelo Rosas",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.38.0",
    "zod": "^3.22.4",
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.23.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "vitest": "^1.0.0"
  }
}
